---
import { footerAuthors } from "../data/site.js";

const { lang, year } = Astro.props;
const isZh = String(lang).startsWith("zh");
const authorsLabel = isZh ? "作者" : "Authors";
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p>Copyright &copy; {year}, Zhiwen Zhou. Released under the BSD 2-Clause License.</p>
    <p>
      <strong>{authorsLabel}:</strong>
      {" "}
      {footerAuthors
        .map((author) => `${author.name} (${author.email})`)
        .join(", ")}
    </p>
  </div>
</footer>
