---
const {
  kicker,
  title,
  description,
  actions = [],
  metrics = [],
  asideTitle,
  asideItems = [],
  imageSrc,
  imageAlt,
} = Astro.props;
---

<section class="page-hero animate">
  <div class="hero-orbit hero-orbit-a" aria-hidden="true"></div>
  <div class="hero-orbit hero-orbit-b" aria-hidden="true"></div>
  <div class="page-hero-grid">
    <div class="hero-copy">
      <div class="hero-kicker-row">
        <p class="hero-kicker">{kicker}</p>
        <span class="hero-kicker-line" aria-hidden="true"></span>
      </div>
      <h1>{title}</h1>
      <p class="hero-description">{description}</p>

      {actions.length > 0 && (
        <div class="hero-actions">
          {actions.map((action) => (
            <a
              href={action.href}
              class:list={["hero-action", { secondary: action.kind === "secondary" }]}
            >
              {action.label}
            </a>
          ))}
        </div>
      )}

      {metrics.length > 0 && (
        <div class="hero-metrics">
          {metrics.map((metric) => (
            <div class="hero-metric">
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <aside class="hero-sidecard">
      {imageSrc && (
        <div class="hero-visual-wrap">
          <div class="hero-visual-grid" aria-hidden="true"></div>
          <img class="hero-visual" src={imageSrc} alt={imageAlt ?? ""} />
          <div class="hero-visual-glow" aria-hidden="true"></div>
        </div>
      )}
      <p class="sidecard-title">{asideTitle}</p>
      <ul class="sidecard-list">
        {asideItems.map((item, index) => (
          <li>
            <span class="sidecard-index">{String(index + 1).padStart(2, "0")}</span>
            <p>{item}</p>
          </li>
        ))}
      </ul>
    </aside>
  </div>
</section>
